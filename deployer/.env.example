DEPLOY_TOKEN=seu_token_secreto_aqui
REPO_PATH=/caminho/do/seu/projeto
COMPOSE_FILE=/caminho/do/seu/projeto/docker-compose.yml
GIT_BRANCH=main
PORT=4000

# ┌─────────────────────────────────────────────────────────────────────┐
# │ CONFIGURAÇÃO DE SERVIÇOS                                            │
# │                                                                      │
# │ Os serviços são configurados no arquivo data/services.json          │
# │ Veja data/services.example.json para um exemplo de estrutura.       │
# │                                                                      │
# │ Ao iniciar, se services.json não existir, ele será criado           │
# │ automaticamente a partir das variáveis SERVICE_* abaixo             │
# │ (retrocompatibilidade).                                             │
# └─────────────────────────────────────────────────────────────────────┘

# Variáveis SERVICE_* (legado - use services.json para novos projetos)
# SERVICE_WEB=webapp
# SERVICE_CRON=cron
# SERVICE_API=api
# SERVICE_DB=postgres

# Prisma Migration (opcional)
# PRISMA_SCHEMA_PATH=/caminho/do/schema.prisma
# PRISMA_SERVICE=prisma-migrate
